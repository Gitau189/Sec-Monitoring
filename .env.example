# Copy to .env and adjust if needed:  cp .env.example .env
# These are DEMO credentials for a classroom project — do NOT reuse in production.

# --- PostgreSQL bootstrap superuser ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=company
# Host port to publish PostgreSQL on. Change to 5433 if you already run a
# local PostgreSQL on 5432 (they will otherwise clash on startup).
POSTGRES_PORT=5432

# --- Grafana admin login (http://localhost:3000) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
